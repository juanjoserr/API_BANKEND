{
  "name": "api-backend",
  "version": "1.0.0",
  "description": "Backend API con Node.js, Express y MySQL",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "docker:build": "docker build -t api-backend .",
    "docker:run": "docker run -p 3000:3000 --env-file .env api-backend",
    "docker:compose": "docker-compose up -d",
    "docker:compose:down": "docker-compose down"
  },
  "keywords": [
    "nodejs",
    "express",
    "mysql",
    "jwt",
    "authentication"
  ],
  "author": "Backend Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mysql2": "^3.6.0",
    "dotenv": "^16.0.3",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
