# ═══════════════════════════════════════════════════════════
# 🔧 CONFIGURACIÓN DE EJEMPLO - RENOMBRA A .env PARA USAR
# ═══════════════════════════════════════════════════════════

# 🗄️ BASE DE DATOS MySQL
# ═════════════════════════════════════════════════════════

# OPCIÓN 1: db4free.net (Recomendado para desarrollo)
# 1. Regístrate en https://www.db4free.net/
# 2. Crea una base de datos
# 3. Copia tus credenciales aquí

DB_HOST=db4free.net
DB_USER=tu_usuario_aqui
DB_PASSWORD=tu_contraseña_aqui
DB_NAME=tu_base_datos_aqui
DB_PORT=3306

# OPCIÓN 2: MySQL Local (Descomentar para usar local)
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=tu_contraseña_local
# DB_NAME=api_backend
# DB_PORT=3306

# 🔐 JWT - TOKEN DE AUTENTICACIÓN
# ═════════════════════════════════════════════════════════

# IMPORTANTE: En producción, usar una clave muy fuerte
# Generar clave aleatoria (Linux/Mac):
# openssl rand -base64 32
# O usar: https://www.uuidgenerator.net/

JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_with_a_strong_key_12345

# 🖥️ CONFIGURACIÓN DEL SERVIDOR
# ═════════════════════════════════════════════════════════

PORT=3000
NODE_ENV=development

# NODE_ENV puede ser: development, production, test

# ═══════════════════════════════════════════════════════════
# PASOS PARA CONFIGURAR:
# ═══════════════════════════════════════════════════════════
#
# 1. Renombra este archivo a .env
# 2. Completa tus credenciales de base de datos
# 3. Cambia JWT_SECRET por una clave segura
# 4. Guarda el archivo
# 5. Inicia el servidor: npm run dev
#
# ═══════════════════════════════════════════════════════════
